# Containerfile that runs a long process under QEMU emulation.
# Used to test whether SIGINT to `podman build` properly cleans up
# child processes (buildah, qemu-*-static) on the remote/VM side.
#
# podman build --platform linux/arm64 -f Containerfile.cleanup-test .

FROM docker.io/library/alpine:latest

# Install a process that will spawn children and be slow to exit.
# The trap ensures the sleep ignores SIGTERM — simulating a stuck QEMU process.
RUN echo "PID $$ starting long-running process" && \
    for i in $(seq 1 4); do \
      sleep 300 & \
      echo "spawned background sleep PID $!"; \
    done && \
    echo "waiting on children..." && \
    wait
