# Control: Go 1.22 does NOT hang under QEMU user-mode emulation.
# Build with: podman build --platform linux/arm64 -f Containerfile.repro-go1.22 .

FROM golang:1.22 AS builder

WORKDIR /app
COPY main.go .
RUN go build -o /app/hello main.go

FROM scratch
COPY --from=builder /app/hello /hello
ENTRYPOINT ["/hello"]
